# Frontend (Vite) environment variables.
# Copy this file to frontend/.env and fill in your Firebase project values.
# Read at build time via import.meta.env.VITE_*; never commit real secrets.
#
# Notes:
# - Every variable MUST use the VITE_ prefix; Vite only exposes VITE_* vars to
#   client code (import.meta.env). Non-prefixed vars are not bundled.
# - The frontend talks to the backend through a relative /api path (proxied by
#   Vite in dev — see vite.config.js), so no API base URL variable is required.
# - These values are read in src/firebaseConfig.js and frontend/index.html.

# Firebase Web API key for this project (Firebase console > Project settings).
VITE_API_KEY=your_firebase_api_key_here
# Firebase Auth domain, e.g. your_project.firebaseapp.com.
VITE_AUTH_DOMAIN=your_project.firebaseapp.com
# Firebase/GCP project id; also used as the app id (window.__app_id) fallback.
VITE_PROJECT_ID=your_project_id
# Cloud Storage bucket for the project, e.g. your_project.appspot.com.
VITE_STORAGE_BUCKET=your_project.appspot.com
# Firebase Cloud Messaging sender id (numeric).
VITE_MESSAGING_SENDER_ID=your_messaging_sender_id
# Firebase web app id (the 1:...:web:... identifier).
VITE_APP_ID=your_firebase_app_id
