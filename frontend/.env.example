# Inspector Bridge WebSocket URL (optional)
# Set this to enable the Inspector Bridge WebSocket connection used for
# remote inspection/debugging. If left unset, the Inspector Bridge WebSocket
# is gracefully disabled and only the postMessage fallback (for the parent
# iframe inspector) is used. No third-party URL is hardcoded in the app.
# Example for connecting to the backend's own server:
#   VITE_WS_URL=ws://localhost:3001/ws/live
VITE_WS_URL=

# Firebase config (optional - for data persistence)
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
