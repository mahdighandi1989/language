# Frontend (Vite) environment variables.
# Copy this file to frontend/.env and fill in your Firebase project values.
# Read at build time via import.meta.env.VITE_*; never commit real secrets.
#
# Notes:
# - Every variable MUST use the VITE_ prefix; Vite only exposes VITE_* vars to
#   client code (import.meta.env). Non-prefixed vars are not bundled.
# - The frontend talks to the backend through a relative /api path (proxied by
#   Vite in dev — see vite.config.js), so no VITE_API_URL base URL variable is
#   required. Do not add VITE_API_URL unless you split the SPA onto a different
#   origin from the API; the relative path keeps prod (single origin) working.
# - These values are read in src/firebaseConfig.js and frontend/index.html.

# Live Voice / Inspector Bridge WebSocket endpoint (optional).
# (Some setups call this VITE_INSPECTOR_WS_URL; in this project the single
# canonical name is VITE_WS_URL — used by src/utils/wsUrl.js for both the Live
# Voice socket and the Inspector Bridge.)
# Leave empty to use this origin's backend /ws/live path automatically (the
# correct setting for production where frontend + backend are served together).
# Set it to point the SPA at a backend on another host/port — e.g. during local
# dev where Vite serves on :5173 and the backend on :3001:
#   VITE_WS_URL=ws://localhost:3001/ws/live
# Never set this to a third-party / hard-coded host.
VITE_WS_URL=

# Firebase web config group. The Firebase console / its docs label these
# VITE_FIREBASE_API_KEY, VITE_FIREBASE_AUTH_DOMAIN, etc.; this project maps each
# VITE_FIREBASE_* value to the shorter VITE_* key below (consumed in
# src/firebaseConfig.js). Fill every key from Firebase console > Project settings.

# Firebase Web API key for this project (Firebase console > Project settings).
VITE_API_KEY=your_firebase_api_key_here
# Firebase Auth domain, e.g. your_project.firebaseapp.com.
VITE_AUTH_DOMAIN=your_project.firebaseapp.com
# Firebase/GCP project id; also used as the app id (window.__app_id) fallback.
VITE_PROJECT_ID=your_project_id
# Cloud Storage bucket for the project, e.g. your_project.appspot.com.
VITE_STORAGE_BUCKET=your_project.appspot.com
# Firebase Cloud Messaging sender id (numeric).
VITE_MESSAGING_SENDER_ID=your_messaging_sender_id
# Firebase web app id (the 1:...:web:... identifier).
VITE_APP_ID=your_firebase_app_id
