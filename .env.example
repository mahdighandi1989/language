# =============================================================================
# Frontend (Vite) environment variables
# Copy this file to frontend/.env and fill in your Firebase project values.
# These are read at build time via import.meta.env.VITE_* and must NOT contain
# real secrets in source control.
# =============================================================================

# Firebase web app configuration
VITE_API_KEY=your_firebase_api_key_here
VITE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_PROJECT_ID=your_project_id
VITE_STORAGE_BUCKET=your_project.appspot.com
VITE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_APP_ID=your_firebase_app_id

# Live Voice / Inspector Bridge WebSocket endpoint (optional). Empty = derive
# from this origin's /ws/live backend path. Set e.g. ws://localhost:3001/ws/live
# in dev to point the SPA at a separate backend host. Never a third-party host.
VITE_WS_URL=
