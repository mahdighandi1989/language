# Gemini API Key - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Port (optional, default 3001)
PORT=3001

# Firebase config (optional - for data persistence)
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# Inspector Bridge WebSocket URL (frontend build-time var, optional).
# Configured in frontend/.env (see frontend/.env.example). If unset, the
# Inspector Bridge WebSocket is gracefully disabled. No third-party URL is
# hardcoded. Example: VITE_WS_URL=ws://localhost:3001/ws/live
