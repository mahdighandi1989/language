# Gemini API Key - Get from https://aistudio.google.com/apikey
# May be stored as plaintext or AES-256-GCM encrypted (iv:authTag:ciphertext).
GEMINI_API_KEY=your_gemini_api_key_here

# Encryption key for AES-256-GCM (32 bytes / 64 hex chars).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# Port (optional, default 3001)
PORT=3001

# CORS: comma-separated list of allowed frontend origins (no wildcard).
# http://localhost:5173 is always allowed for local development.
CORS_ORIGIN=https://your-production-domain.com
FRONTEND_URL=https://your-production-domain.com

# Notifications for critical events (e.g. verify_failed). Optional: when both
# are set, alerts are delivered to Telegram; otherwise they are logged.
NOTIFY_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
NOTIFY_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =============================================================================
# Two-way Telegram bot (notifications + remote control + AI practice).
# Optional: with no TELEGRAM_BOT_TOKEN the bot stays dormant and the server
# runs normally. Create a bot and get the token from @BotFather.
# Full user guide: docs/telegram-user-guide.md
# =============================================================================

# Bot token from @BotFather. Falls back to NOTIFY_TELEGRAM_BOT_TOKEN if unset.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Update source: "polling" (default) or "webhook". Webhook needs a public HTTPS
# URL and is auto-selected when TELEGRAM_WEBHOOK_URL is set.
TELEGRAM_MODE=polling
# Public HTTPS URL Telegram should POST updates to (must end in
# /api/telegram/webhook). Leave empty to use long polling instead.
TELEGRAM_WEBHOOK_URL=
# Secret echoed by Telegram in the X-Telegram-Bot-Api-Secret-Token header so the
# webhook endpoint can reject forged requests. Recommended for webhook mode.
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram numeric user ids allowed to run write commands
# (add/edit/delete courses, upload). Empty = open (any chat may write).
TELEGRAM_ALLOWED_USER_IDS=
# Comma-separated Telegram numeric user ids with admin commands (/admin_logs).
TELEGRAM_ADMIN_IDS=
# Default chat id for system notifications when no user has linked their chat.
# Falls back to NOTIFY_TELEGRAM_CHAT_ID.
TELEGRAM_CHAT_ID=
# Directory for the bot's JSON data store (default: backend/data).
TELEGRAM_DATA_DIR=

# Firebase Admin / config (server-side; used for ID token verification)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
